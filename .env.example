# ThirtyCLI — Environment Config
# Copy file ini jadi .env dan isi sesuai kebutuhan
# (opsional — bisa juga setup lewat wizard saat pertama run)

# Provider: openrouter | 9router | both
THIRTY_PROVIDER=openrouter

# OpenRouter API Key
# Dapetin gratis di: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxx

# Model default (OpenRouter model ID)
# Contoh free models:
#   deepseek/deepseek-r1-0528:free
#   google/gemini-2.5-flash:free
#   qwen/qwen3-coder:free
THIRTY_MODEL=deepseek/deepseek-r1-0528:free

# 9Router URL (kalau pakai 9Router)
# Default: http://localhost:20128/v1
NINE_ROUTER_URL=http://localhost:20128/v1
